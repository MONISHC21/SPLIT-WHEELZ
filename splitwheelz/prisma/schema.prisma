generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum VehicleStatus {
  AVAILABLE
  FULLY_BOOKED
  MAINTENANCE
  INACTIVE
}

enum VehicleType {
  SEDAN
  SUV
  HATCHBACK
  LUXURY
  SPORTS
  VAN
  TRUCK
  BIKE
  ELECTRIC
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentType {
  SLOT_PURCHASE
  BOOKING_PAYMENT
  MAINTENANCE_CONTRIBUTION
  INSURANCE_PAYMENT
  PENALTY
  REFUND
}

enum OwnershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TRANSFERRED
  SOLD
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
  ESCALATED
}

enum DisputeType {
  BOOKING_CONFLICT
  DAMAGE_REPORT
  PAYMENT_DISPUTE
  MAINTENANCE_DISAGREEMENT
  GENERAL
}

enum VoteType {
  MAINTENANCE
  RULE_CHANGE
  OWNERSHIP_SALE
  EXPENSE_APPROVAL
  GENERAL
}

model User {
  id              String   @id @default(cuid())
  firebaseUid     String   @unique
  email           String   @unique
  phone           String?  @unique
  name            String
  avatar          String?
  role            UserRole @default(USER)
  isActive        Boolean  @default(true)
  isBanned        Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  fcmTokens       String[]
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  country         String   @default("India")
  drivingLicense  String?
  aadhaarNumber   String?
  panNumber       String?
  kycVerified     Boolean  @default(false)
  kycDocuments    Json?
  totalBookings   Int      @default(0)
  totalSpent      Decimal  @default(0) @db.Decimal(12, 2)
  loyaltyPoints   Int      @default(0)
  referralCode    String   @unique @default(cuid())
  referredBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ownerships     VehicleOwnership[]
  bookings       Booking[]
  payments       Payment[]
  notifications  Notification[]
  disputes       Dispute[]          @relation("DisputeRaiser")
  votes          Vote[]
  chatMessages   ChatMessage[]
  reviews        Review[]
  activities     ActivityLog[]

  @@index([email])
  @@index([firebaseUid])
  @@index([phone])
}

model Vehicle {
  id                     String        @id @default(cuid())
  make                   String
  model                  String
  year                   Int
  registrationNumber     String        @unique
  vin                    String?       @unique
  color                  String
  type                   VehicleType
  fuelType               FuelType
  transmission           String        @default("manual")
  seatingCapacity        Int           @default(5)
  mileage                Decimal?      @db.Decimal(8, 2)
  engineCC               Int?
  images                 String[]
  description            String?
  features               String[]
  insuranceExpiry        DateTime?
  pucExpiry              DateTime?
  lastServiceDate        DateTime?
  nextServiceDate        DateTime?
  status                 VehicleStatus @default(AVAILABLE)
  totalSlots             Int           @default(2)
  availableSlots         Int           @default(2)
  pricePerSlot           Decimal       @db.Decimal(12, 2)
  monthlyMaintenanceCost Decimal       @default(0) @db.Decimal(10, 2)
  insuranceCost          Decimal       @default(0) @db.Decimal(10, 2)
  location               String?
  latitude               Decimal?      @db.Decimal(10, 7)
  longitude              Decimal?      @db.Decimal(10, 7)
  averageRating          Decimal       @default(0) @db.Decimal(3, 2)
  totalReviews           Int           @default(0)
  isVerified             Boolean       @default(false)
  isFeatured             Boolean       @default(false)
  totalBookings          Int           @default(0)
  addedById              String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  ownerships   VehicleOwnership[]
  bookings     Booking[]
  documents    VehicleDocument[]
  reviews      Review[]
  votes        Vote[]
  chatRooms    ChatRoom[]
  expenses     VehicleExpense[]
  maintenance  MaintenanceRecord[]

  @@index([status])
  @@index([type])
  @@index([location])
  @@index([make, model])
}

model VehicleOwnership {
  id              String          @id @default(cuid())
  vehicleId       String
  userId          String
  slotNumber      Int
  ownershipShare  Decimal         @default(25) @db.Decimal(5, 2)
  purchasePrice   Decimal         @db.Decimal(12, 2)
  purchaseDate    DateTime        @default(now())
  status          OwnershipStatus @default(PENDING)
  isAdmin         Boolean         @default(false)
  weeklyHours     Int             @default(42)
  usageThisMonth  Decimal         @default(0) @db.Decimal(8, 2)
  totalUsage      Decimal         @default(0) @db.Decimal(10, 2)
  pendingCharges  Decimal         @default(0) @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, slotNumber])
  @@unique([vehicleId, userId])
  @@index([userId])
  @@index([vehicleId])
}

model Booking {
  id              String        @id @default(cuid())
  vehicleId       String
  userId          String
  startTime       DateTime
  endTime         DateTime
  durationHours   Decimal       @db.Decimal(6, 2)
  purpose         String?
  pickupLocation  String?
  dropLocation    String?
  status          BookingStatus @default(PENDING)
  totalAmount     Decimal       @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  finalAmount     Decimal       @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?
  startOdometer   Int?
  endOdometer     Int?
  cancellationReason String?
  cancelledAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  payments  Payment[]
  disputes  Dispute[]
  reviews   Review[]

  @@index([vehicleId])
  @@index([userId])
  @@index([startTime, endTime])
  @@index([status])
}

model Payment {
  id                  String        @id @default(cuid())
  userId              String
  bookingId           String?
  vehicleId           String?
  ownershipId         String?
  type                PaymentType
  amount              Decimal       @db.Decimal(12, 2)
  currency            String        @default("INR")
  status              PaymentStatus @default(PENDING)
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  description         String?
  metadata            Json?
  refundId            String?
  refundAmount        Decimal?      @db.Decimal(12, 2)
  refundReason        String?
  refundedAt          DateTime?
  failureReason       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([bookingId])
  @@index([razorpayOrderId])
  @@index([status])
}

model VehicleDocument {
  id          String   @id @default(cuid())
  vehicleId   String
  name        String
  type        String
  url         String
  expiryDate  DateTime?
  isVerified  Boolean  @default(false)
  uploadedAt  DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String
  data        Json?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  isSent      Boolean  @default(false)
  sentAt      DateTime?
  channel     String   @default("in_app")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Dispute {
  id          String        @id @default(cuid())
  raisedById  String
  vehicleId   String?
  bookingId   String?
  type        DisputeType
  title       String
  description String
  status      DisputeStatus @default(OPEN)
  priority    String        @default("medium")
  evidence    String[]
  resolution  String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  raisedBy User     @relation("DisputeRaiser", fields: [raisedById], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@index([raisedById])
  @@index([status])
}

model Vote {
  id          String   @id @default(cuid())
  vehicleId   String
  createdById String
  type        VoteType
  title       String
  description String
  options     Json
  votes       Json     @default("{}")
  isActive    Boolean  @default(true)
  deadline    DateTime
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  voters    User[]

  @@index([vehicleId])
  @@index([isActive])
}

model ChatRoom {
  id        String   @id @default(cuid())
  vehicleId String
  name      String
  createdAt DateTime @default(now())

  vehicle  Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([vehicleId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  message    String
  attachments String[]
  isEdited   Boolean  @default(false)
  editedAt   DateTime?
  createdAt  DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@index([roomId])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  vehicleId String
  userId    String
  bookingId String?
  rating    Int
  title     String?
  comment   String?
  images    String[]
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@unique([vehicleId, userId, bookingId])
  @@index([vehicleId])
  @@index([userId])
}

model VehicleExpense {
  id          String   @id @default(cuid())
  vehicleId   String
  title       String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  receipt     String?
  addedById   String
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  vehicleId   String
  type        String
  description String
  cost        Decimal  @db.Decimal(10, 2)
  vendor      String?
  serviceDate DateTime
  nextDueDate DateTime?
  odometer    Int?
  receipt     String?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
